{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    // 🚫 Previene que se generen archivos .js
    "noEmit": true,

    // 👇 Útil si querés limpiar errores molestos que no te afectan
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src"]
}